# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only for bulk user scripts (scripts/create-auth-users.mjs)
# Supabase Dashboard → Settings → API → service_role (keep secret, never commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Windows office server photo sync (scripts/windows-photo-sync.mjs)
# PHOTOS_ROOT=D:\MalconNexus\Photos
# PHOTOS_SYNC_MAX_DOWNLOADS_PER_RUN=20
# PHOTOS_SYNC_MAX_CASES=100
# PHOTOS_SYNC_LOOKBACK_DAYS=90
# PHOTOS_CLEANUP_RETENTION_DAYS=30
# PHOTOS_CLEANUP_MAX_DELETIONS_PER_RUN=50

# Email (Resend) — set in Supabase Edge Function secrets, NOT in .env or Vercel
# Dashboard → Project Settings → Edge Functions → Secrets:
#   RESEND_API_KEY=re_xxxx
#   RESEND_FROM_EMAIL=noreply@malconnexus.com
#   APP_URL=https://malconnexus.com
# Deploy: supabase functions deploy send-assignment-email
#          supabase functions deploy update-employee-login-email
