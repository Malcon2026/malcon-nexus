# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only for bulk user scripts (scripts/create-auth-users.mjs)
# Supabase Dashboard → Settings → API → service_role (keep secret, never commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email (Resend) — set in Supabase Edge Function secrets, NOT in .env or Vercel
# Dashboard → Project Settings → Edge Functions → Secrets:
#   RESEND_API_KEY=re_xxxx
#   RESEND_FROM_EMAIL=onboarding@resend.dev
#   APP_URL=https://your-vercel-url.vercel.app
# Deploy: supabase functions deploy send-assignment-email
